# Example frontend env (copy to .env.local)

# Leave empty in local Vite dev to use the /api and /v1 proxies (see vite.config.ts).
# For production / preview against a remote API:
VITE_API_URL=https://api.meridian.dev
VITE_DOCS_URL=/docs

# Optional: override the Vite proxy target (default http://localhost:3080)
# VITE_DEV_API_PROXY=http://localhost:3080
