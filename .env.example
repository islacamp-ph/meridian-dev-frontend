# Example frontend env (copy to .env.local)

# LOCAL DEV: leave VITE_API_URL unset/commented so Vite proxies /api and /v1
# to http://localhost:3080 (go-gateway). Start backend first:
#   cd ../meridian-dev-backend && npm run docker:up && npm run docker:wait
#
# PRODUCTION: prefer same-origin (unset VITE_API_URL) + Vercel rewrites to your API,
# so session cookies stay first-party. If the SPA calls a different API origin,
# set VITE_API_URL and on the API: COOKIE_SAMESITE=none, COOKIE_SECURE=true,
# CORS_ORIGINS=https://your-frontend-host
# VITE_API_URL=https://api.meridianapp.dev

# Optional: point the Vite proxy at a different API (e.g. direct ts-api)
# VITE_DEV_API_PROXY=http://localhost:3080
# VITE_DEV_API_PROXY=http://localhost:3001

# Public docs (Starlight). Default: in-site /docs quickstart.
# VITE_DOCS_URL=https://docs.meridian.dev
VITE_DOCS_URL=/docs
